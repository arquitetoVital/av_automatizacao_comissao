# Renomeie este arquivo para .env e preencha com suas credenciais.
# NUNCA commite o arquivo .env no repositório.

OMIE_APP_KEY=seu_app_key_aqui
OMIE_APP_SECRET=seu_app_secret_aqui

GITHUB_TOKEN=Personal Access Token com escopo "Contents: Read & Write"
GITHUB_REPO =ex: "minha-org/meu-repo-privado"
GITHUB_BRANCH=branch de destino (padrão: "main")
GITHUB_JSON_PATH=caminho do arquivo no repo (padrão: "data/{ANO_MES}.json")

PASTA_COORD=
PASTA_VENDEDOR_SP=
PASTA_VENDEDOR_MG=
PASTA_COMPRADOR=

PASTA_ANALISTA=
RELATORIO_ANALISTA_ATIVO=#true/false